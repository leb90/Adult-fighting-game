{
  "name": "fytefans-fighter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "build:electron": "vite build --base ./",
    "electron:preview": "npm run build:electron && electron .",
    "electron:dist": "npm run build:electron && electron-packager . FyteFans --platform=win32 --arch=x64 --out=release --overwrite --asar --ignore=\"^/(src|public|\\.git|node_modules)\""
  },
  "dependencies": {
    "gsap": "^3.12.5"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "gh-pages": "^6.3.0",
    "gif-encoder-2": "^1.0.5",
    "sharp": "^0.34.5",
    "vite": "^5.4.2"
  }
}
